# =============================================================================
# AI PRODUCT STUDIO — .gitignore
# =============================================================================

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
secrets/
*.pem
*.key

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.dmypy.json
.pytype/
cython_debug/
.venv/
venv/
ENV/
env/

# ─── Node.js / Frontend ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.vite/
*.local
coverage/
*.tsbuildinfo

# ─── IDE & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── OS Generated ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs & Databases ────────────────────────────────────────────────────────
*.log
*.sql
*.sqlite
*.sqlite3
logs/
log/

# ─── Deliverables (Client Generated Data) ────────────────────────────────────
deliverables/*
!deliverables/.gitkeep

# ─── Build Outputs ───────────────────────────────────────────────────────────
build/
out/
dist/
*.tgz
*.tar.gz
*.zip

# ─── Docker ──────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─── Testing ─────────────────────────────────────────────────────────────────
.coverage
htmlcov/
.tox/
.nox/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
